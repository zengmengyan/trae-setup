# ============================================================
# MCP Token 配置文件
# 复制此文件为 .mcp.env 并填入你的 Token
# .mcp.env 已被 .gitignore 忽略，不会提交到 Git
# ============================================================
#
# 格式: KEY=VALUE
# 注意: 值中不要包含引号或多余空格
#

# GitHub Personal Access Token
# 需要权限: repo, issues, pull_requests, workflows
# 创建地址: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here
